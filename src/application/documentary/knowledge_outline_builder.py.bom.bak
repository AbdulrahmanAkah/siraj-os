from application.models.outline import DocumentaryOutline


class KnowledgeOutlineBuilder:

    def build(
        self,
        graph,
        topic: str,
    ) -> DocumentaryOutline:

        node_types = getattr(graph.index, "nodes_by_type", {})

        sections = []

        mapping = [
            ("PERSON", "الشخصيات"),
            ("EVENT", "الأحداث"),
            ("TIMELINE_EVENT", "التسلسل الزمني"),
            ("LOCATION", "الأماكن"),
            ("STATISTIC", "الإحصاءات"),
            ("CLAIM", "الحقائق والاستنتاجات"),
        ]

        for node_type, title in mapping:
            if node_types.get(node_type):
                sections.append(title)

        intro = (
            f"يستعرض هذا الفيلم الوثائقي موضوع {topic} "
            "اعتماداً على المعرفة المستخرجة من المصادر."
        )

        conclusion = (
            "وبذلك تكتمل الصورة اعتماداً على الوقائع والعلاقات "
            "المستخرجة من المصادر."
        )

        return DocumentaryOutline(
            title=topic,
            introduction=intro,
            sections=sections,
            conclusion=conclusion,
        )


__all__ = ["KnowledgeOutlineBuilder"]
